RewriteEngine On

# Send API requests to Laravel backend - preserve method
RewriteCond %{REQUEST_URI} ^/myholi/api/(.*)$
RewriteRule ^api/(.*)$ backend/public/index.php [L,QSA,E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

RewriteRule ^api/(.*)$ backend/public/index.php [L,QSA]

# Allow existing files (JS, CSS, images, directories)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Frontend routing (React / Vite SPA) - handle all other requests
RewriteRule ^(.*)$ index.html [L]
